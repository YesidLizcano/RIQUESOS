# ============================================
# Backoffice Riquesos - Variables de Entorno
# ============================================
# Copie este archivo como .env y configure los valores

# Secreto para JWT (cambie por un valor aleatorio largo en producción)
NEXTAUTH_SECRET=cambie-esto-por-un-secreto-aleatorio

# URL del servidor (no cambiar si corre localmente)
NEXTAUTH_URL=http://localhost:3000

# Ruta de la base de datos SQLite
DATABASE_URL="file:./dev.db"