generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum TipoProducto {
  DOBLE_CREMA
  SEMISALADO
}

enum TipoCliente {
  MAYORISTA
  MINORISTA
}

enum EstadoLote {
  ACTIVO
  AGOTADO
}

enum RolUsuario {
  ADMIN
  USER
}

model Proveedor {
  id         String    @id @default(uuid())
  nombre     String
  telefono   String?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lotes      Lote[]

  @@index([deletedAt])
}

model Lote {
  id                     String       @id @default(uuid())
  producto               TipoProducto
  fechaIngreso           DateTime     @default(now())
  proveedorId            String
  proveedor              Proveedor    @relation(fields: [proveedorId], references: [id])
  cantidadCompradaKg     Decimal      @default("0")
  precioCompraBaseKg     Decimal      @default("0")
  costoFlete             Decimal      @default("0")
  costoTajado            Decimal      @default("0")
  costoEmpaques          Decimal      @default("0")
  costoRealCalculadoKg   Decimal      @default("0")
  stockDisponibleKg      Decimal      @default("0")
  bloquesEnteros         Int          @default(0)
  bloquesTajados         Int          @default(0)
  bloquesTajadosDeFabrica Int         @default(0)
  estado                 EstadoLote   @default(ACTIVO)
  version                Int          @default(1)
  deletedAt              DateTime?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  ventas                 Venta[]
  tajados                Tajado[]

  @@index([deletedAt])
}

model Tajado {
  id              String   @id @default(uuid())
  loteId          String
  lote            Lote     @relation(fields: [loteId], references: [id])
  cantidadBloques Int
  precioPorBloque Decimal  @default("1500")
  tajador         String
  costoTotal      Decimal  @default("0")
  fecha           DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([loteId])
  @@index([fecha])
}

model Cliente {
  id               String       @id @default(uuid())
  nombre            String
  tipo              TipoCliente
  precioDobleCrema  Decimal?
  precioSemisalado  Decimal?
  deletedAt         DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  ventas            Venta[]

  @@index([deletedAt])
}

model Venta {
  id               String   @id @default(uuid())
  fecha            DateTime @default(now())
  clienteId        String
  cliente          Cliente  @relation(fields: [clienteId], references: [id])
  loteId           String
  lote             Lote     @relation(fields: [loteId], references: [id])
  cantidadVendidaKg Decimal @default("0")
  precioVentaKg    Decimal  @default("0")
  ingresoTotal     Decimal  @default("0")
  costoAplicado    Decimal  @default("0")
  gananciaBruta    Decimal  @default("0")
  valorDomicilio   Decimal  @default("0")
  domiciliario     String   @default("")
  createdAt        DateTime @default(now())
}

model GastoFijo {
  id        String    @id @default(uuid())
  fecha     DateTime  @default(now())
  concepto  String
  valor     Decimal   @default("0")
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([deletedAt])
}

model Usuario {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String
  role         RolUsuario  @default(ADMIN)
  deletedAt    DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  auditLogs    AuditLog[]
}

model AuditLog {
  id          String   @id @default(uuid())
  entityType  String
  entityId    String
  action      String
  userId      String?
  changes     String?
  createdAt   DateTime @default(now())

  user Usuario? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}